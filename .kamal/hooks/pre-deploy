#!/bin/bash
set -euo pipefail

# Run migrations in the NEW version container before swapping traffic.
# Only runs for the main API service — skipped for MCP, worker, and frontend deploys.
# Aborts the deploy if migrations fail.
#
# Uses --version to run in the newly-built container (which has secrets injected),
# not the currently-running one. Uses -p to run on the primary host only.

if [ "$KAMAL_SERVICE" = "scout" ]; then
  echo "Running migrations..."
  kamal app exec -p --version "$KAMAL_VERSION" -- python manage.py migrate --no-input
fi
